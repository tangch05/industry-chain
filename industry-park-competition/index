        function parseDimensionOptimizationResponse(text, dimension) {
            const subDims = stepOneDimensionStructure[dimension];
            const normalized = text.replace(/\r\n/g, '\n');
            const updates = {};

            subDims.forEach((subDim, index) => {
                const nextSub = subDims[index + 1];
                const escapedSub = escapeRegex(subDim);
                const escapedNext = nextSub ? escapeRegex(nextSub) : null;
                const sectionRegex = escapedNext
                    ? new RegExp(`${escapedSub}[：:]([\\s\\S]*?)(?=\\n\\s*${escapedNext}[：:])`)
                    : new RegExp(`${escapedSub}[：:]([\\s\\S]*)`);
                const match = normalized.match(sectionRegex);
                if (!match) return;

                const section = match[1].trim();
                updates[subDim] = {};
                currentParks.forEach((park, parkIdx) => {
                    const nextPark = currentParks[parkIdx + 1];
                    const escapedPark = escapeRegex(park);
                    const escapedNextPark = nextPark ? escapeRegex(nextPark) : null;
                    const parkRegex = escapedNextPark
                        ? new RegExp(`${escapedPark}[：:]([\\s\\S]*?)(?=\\n\\s*${escapedNextPark}[：:])`)
                        : new RegExp(`${escapedPark}[：:]([\\s\\S]*)`);
                    const parkMatch = section.match(parkRegex);
                    if (parkMatch) {
                        updates[subDim][park] = parkMatch[1].replace(/\n+/g, ' ').trim().slice(0, 400);
                    }
                });
            });

            return updates;
        }

        function applyDimensionUpdates(dimension, updates) {
            const subDims = stepOneDimensionStructure[dimension];
            subDims.forEach(subDim => {
                const key = `${dimension}-${subDim}`;
                if (!detailedData[key]) detailedData[key] = {};
                currentParks.forEach(park => {
                    if (updates[subDim] && updates[subDim][park]) {
                        detailedData[key][park] = updates[subDim][park].slice(0, 400);
                    }
                });
            });
        }

