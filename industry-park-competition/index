                });
                row.innerHTML = html;
                tbody.appendChild(row);
            });
        }

        function renderScoreTable(scores, parks) {
            const thead = document.querySelector('#scoreTable thead tr');
            const tbody = document.getElementById('scoreTableBody');
            thead.innerHTML = '<th class="border border-gray-300 px-4 py-3 text-left font-bold text-gray-800 w-40 bg-gray-100">评价维度</th>';

            parks.forEach((park, idx) => {
                const isTarget = idx === parks.length - 1;
                const bgClass = isTarget ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800';
                thead.innerHTML += `<th class="border border-gray-300 px-4 py-3 text-center font-bold ${bgClass}">${park}${isTarget ? '（本园区）' : ''}</th>`;
            });

            tbody.innerHTML = '';
            mainDimensions.forEach(dim => {
                const row = document.createElement('tr');
                row.className = 'hover:bg-gray-50 transition';
                let html = `<td class="border border-gray-300 px-4 py-3 font-bold text-gray-700 bg-gray-50">${dim}</td>`;

                parks.forEach((park, idx) => {
                    const isTarget = idx === parks.length - 1;
                    const score = (scores[dim] && scores[dim][park]) || 0;
                    const percentage = Math.max(0, Math.min(100, (score / 10) * 100));
                    html += `
                        <td class="border border-gray-300 px-4 py-3 ${isTarget ? 'bg-blue-50/30' : ''}">
                            <div class="flex items-center gap-3 justify-center">
                                <input type="number"
                                       class="score-input"
                                       value="${score.toFixed(1)}"
                                       min="0"
                                       max="10"
                                       step="0.1"
                                       data-dimension="${dim}"
                                       data-park="${park}"
                                       onchange="handleScoreChange(this)"
                                       onblur="validateScore(this)">
                                <div class="w-24 h-6 bg-gray-200 rounded-full overflow-hidden relative shadow-inner flex-1 max-w-[120px]">
                                    <div class="${parkBarColors[idx % parkBarColors.length]} h-full rounded-full transition-all duration-500 ease-out shadow-sm score-bar"
                                         style="width: ${percentage}%"
                                         data-dim="${dim}"
                                         data-park="${park}"></div>
                                </div>
                            </div>
                        </td>
                    `;
                });
                row.innerHTML = html;
                tbody.appendChild(row);
            });
        }

        function handleCellEdit(cell) {
            const step = cell.getAttribute('data-step');
            const table = cell.getAttribute('data-table');
            const dimension = cell.getAttribute('data-dimension');
            const park = cell.getAttribute('data-park');
            const newText = cell.innerText.trim();

            if (!dimension || !park) return;

            if (step === 'one') {
                if (newText.length > 400) {
                    alert('内容超过400字限制，请精简描述');
                    const clipped = newText.slice(0, 400);
                    cell.innerText = clipped;
                    if (!detailedData[dimension]) detailedData[dimension] = {};
                    detailedData[dimension][park] = clipped;
                } else {
                    if (!detailedData[dimension]) detailedData[dimension] = {};
                    detailedData[dimension][park] = newText;
                }
                cell.style.backgroundColor = 'rgba(255, 255, 200, 0.3)';
                return;
            }

            if (step === 'two' && currentData) {
                if (table === 'detail') {
                    const clipped = newText.slice(0, 400);
                    if (clipped.length !== newText.length) {
                        alert('内容超过400字限制，已自动截断');
                        cell.innerText = clipped;
                    }
                    if (!currentData.details[dimension]) currentData.details[dimension] = {};
                    currentData.details[dimension][park] = clipped;
                }
                if (table === 'summary') {
                    const clipped = newText.slice(0, 50);
                    if (clipped.length !== newText.length) {
                        alert('总结建议控制在20字内，已自动截断');
                        cell.innerText = clipped;
                    }
                    if (!currentData.summaries[dimension]) currentData.summaries[dimension] = {};
                    currentData.summaries[dimension][park] = clipped;
                }
                cell.style.backgroundColor = 'rgba(255, 255, 200, 0.3)';
            }
        }

        function handleScoreChange(input) {
            if (!currentData) return;
            let value = parseFloat(input.value);
            const dim = input.getAttribute('data-dimension');
            const park = input.getAttribute('data-park');

            if (!Number.isFinite(value)) value = 0;
            value = Math.max(0, Math.min(10, value));

            if (!currentData.scores[dim]) currentData.scores[dim] = {};
            currentData.scores[dim][park] = parseFloat(value.toFixed(1));
            input.value = currentData.scores[dim][park].toFixed(1);

            const percentage = (currentData.scores[dim][park] / 10) * 100;
            const bar = document.querySelector(`.score-bar[data-dim="${dim}"][data-park="${park}"]`);
            if (bar) bar.style.width = `${percentage}%`;

            updateSummaryBars(dim);
        }

        function validateScore(input) {
            let value = parseFloat(input.value);
            if (!Number.isFinite(value) || value < 0 || value > 10) {
                alert('评分必须在0-10之间');
                input.value = '7.0';
                handleScoreChange(input);
            }
        }

        function updateSummaryBars(changedDim) {
            if (!currentData || !currentData.scores[changedDim]) return;
            const maxScore = Math.max(...Object.values(currentData.scores[changedDim]));
            currentParks.forEach(park => {
                const score = currentData.scores[changedDim][park] || 0;
                const percentage = maxScore > 0 ? (score / maxScore) * 100 : 0;
                const bar = document.querySelector(`.summary-bar[data-dim="${changedDim}"][data-park="${park}"]`);
                if (bar) bar.style.width = `${percentage}%`;
            });
        }

        async function refreshAnalysis() {
            if (!currentData || !currentParks.length) {
                alert('请先完成“确认生成”步骤');
                return;
            }

            document.getElementById('refreshLoadingArea').classList.remove('hidden');
            document.getElementById('refreshBtn').disabled = true;

            try {
                const prompt = buildRefreshPrompt();
                const response = await callAI(prompt, currentModel, userApiKey);
                const parsed = parseRefreshResponse(response);

                currentData.summaries = normalizeSummaries(parsed.summaries || currentData.summaries);
                currentData.scores = normalizeScores(parsed.scores || currentData.scores);
                currentData.report = parsed.report || currentData.report;

                renderSummaryTable(currentData.summaries, currentData.scores, currentParks);
                renderScoreTable(currentData.scores, currentParks);
                document.getElementById('summaryText').innerHTML = formatReport(currentData.report);
                document.getElementById('generateTime').textContent = new Date().toLocaleString('zh-CN') + ' (已刷新)';

                alert('刷新成功！已根据当前详细情况重新生成总结、评分和报告。');
            } catch (error) {
                console.error('刷新失败:', error);
                alert('刷新失败：' + error.message);
            } finally {
                document.getElementById('refreshLoadingArea').classList.add('hidden');
                document.getElementById('refreshBtn').disabled = false;
            }
        }

        function buildRefreshPrompt() {
            const detailBlocks = Object.entries(finalDimensionStructure).map(([mainDim, subDims]) => {
                const subs = subDims.map(subDim => {
                    const key = `${mainDim}-${subDim}`;
                    return `${subDim}:\n${currentParks.map(park => `${park}: ${(currentData.details[key] || {})[park] || ''}`).join('\n')}`;
                }).join('\n\n');
                return `${mainDim}\n${subs}`;
            }).join('\n\n');

            return `基于以下“详细情况大表”内容，重新生成一句话总结、数值评分和报告，不要重新生成详细情况数据。\n\n${detailBlocks}\n\n园区：${currentParks.join('、')}（${targetParkName}为本园区）\n\n请严格返回JSON：
{
  "summaries": {
    "产业集聚力": {"园区A": "20字内"},
    "创新突破力": {"园区A": "20字内"},
    "要素吸引力": {"园区A": "20字内"},
    "风险抵御力": {"园区A": "20字内"},
    "综合竞争力评价": {"园区A": "20字内"}
  },
  "scores": {
    "产业集聚力": {"园区A": 8.5},
    "创新突破力": {"园区A": 8.5},
    "要素吸引力": {"园区A": 8.5},
    "风险抵御力": {"园区A": 8.5},
    "综合竞争力评价": {"园区A": 8.5}
  },
  "report": "详细报告文本"
}`;
        }

        function parseRefreshResponse(content) {
            const jsonMatch = content.match(/\{[\s\S]*\}/);
            if (!jsonMatch) {
                throw new Error('刷新返回格式异常');
            }
            return JSON.parse(jsonMatch[0]);
        }

        function formatReport(report) {
            const parts = (report || '').split(/\n\n+/).map(p => p.trim()).filter(Boolean);
            if (!parts.length) return '<p class="text-gray-600">暂无报告内容</p>';
            return parts.map(para => `<p class="indent-8 mb-3 text-gray-700 leading-7">${escapeHTML(para)}</p>`).join('');
        }

        function generateFallbackReport() {
            return `本次分析采用“两步式校准”机制：第一步由实时搜索与AI生成四维详细内容并允许人工校正，第二步基于最终明细统一生成总结、评分与综合判断。\n\n从对比结果看，各园区在产业基础、创新活力、要素保障与风险韧性方面各有优势。本园区在部分维度具备基础优势，但在高端产业链环节、创新策源能力和要素能级上仍有提升空间。\n\n建议围绕“补链强链、强化创新平台、优化政策供给、提升风险预警能力”持续发力，推动园区综合竞争力稳步提升。`;
        }

        function escapeHTML(str) {
            return String(str || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function escapeRegex(str) {
            return String(str).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        }

        function resetForm() {
            document.getElementById('compareParks').value = '';
            document.getElementById('targetPark').value = '';
            document.getElementById('apiKey').value = '';
            document.getElementById('tavilyApiKey').value = '';

            document.getElementById('searchStatus').classList.add('hidden');
            document.getElementById('stepOneArea').classList.add('hidden');
            document.getElementById('resultArea').classList.add('hidden');
            document.getElementById('loadingArea').classList.add('hidden');
            document.getElementById('refreshLoadingArea').classList.add('hidden');

            document.getElementById('confirmGenerateBtn').disabled = true;
            document.getElementById('refreshBtn').classList.add('hidden');
            document.getElementById('exportBtn').classList.add('hidden');
            document.getElementById('exportWordBtn').classList.add('hidden');

            currentParks = [];
            targetParkName = '';
            currentModel = '';
            userApiKey = '';
            userTavilyApiKey = '';
            detailedData = {};
            conversationHistory = {};
            currentData = null;

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        async function exportPDF() {
            const element = document.getElementById('resultArea');
            if (element.classList.contains('hidden')) {
                alert('请先完成第二步并生成最终结果');
                return;
            }

            const btn = document.getElementById('exportBtn');
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<div class="loading-spinner w-5 h-5 border-2"></div><span>生成中...</span>';

            try {
                const canvas = await html2canvas(element, {
                    scale: 2,
                    useCORS: true,
                    logging: false,
                    windowWidth: element.scrollWidth,
                    windowHeight: element.scrollHeight
                });

                const imgData = canvas.toDataURL('image/png');
                const { jsPDF } = window.jspdf;
                const pdf = new jsPDF('p', 'mm', 'a4');

                const imgWidth = 210;
                const pageHeight = 297;
                const imgHeight = canvas.height * imgWidth / canvas.width;

                let heightLeft = imgHeight;
                let position = 0;

                pdf.addImage(imgData, 'PNG', 0, position, imgWidth, imgHeight);
                heightLeft -= pageHeight;

                while (heightLeft > 0) {
                    position = heightLeft - imgHeight;
                    pdf.addPage();
                    pdf.addImage(imgData, 'PNG', 0, position, imgWidth, imgHeight);
                    heightLeft -= pageHeight;
                }

                pdf.save(`园区竞争力对比分析报告_${new Date().toISOString().slice(0, 10)}.pdf`);
            } catch (error) {
                console.error('PDF导出失败:', error);
                alert('PDF导出失败，请重试');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }

        async function exportWord() {
            if (!currentData) {
                alert('请先完成第二步并生成最终结果');
                return;
            }

            const btn = document.getElementById('exportWordBtn');
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<div class="loading-spinner w-5 h-5 border-2"></div><span>生成中...</span>';

            try {
                const {
                    Document, Packer, Paragraph, Table, TableCell, TableRow,
                    TextRun, WidthType, AlignmentType, HeadingLevel, BorderStyle, VerticalAlign
                } = docx;

                const parks = currentParks;

                const detailRows = [];
                detailRows.push(new TableRow({
                    children: [
                        new TableCell({ children: [new Paragraph({ text: '评估维度', bold: true })], shading: { fill: 'F3F4F6' } }),
                        new TableCell({ children: [new Paragraph({ text: '细化评估维度', bold: true })], shading: { fill: 'F3F4F6' } }),
                        ...parks.map(park => new TableCell({
                            children: [new Paragraph({ text: park + (park === targetParkName ? '（本园区）' : ''), bold: true, alignment: AlignmentType.CENTER })],
                            shading: { fill: park === targetParkName ? 'DBEAFE' : 'F3F4F6' }
                        }))
                    ]
                }));

                Object.entries(finalDimensionStructure).forEach(([mainDim, subDims]) => {
                    subDims.forEach((subDim, idx) => {
                        const key = `${mainDim}-${subDim}`;
                        const cells = [];

                        if (idx === 0) {
                            cells.push(new TableCell({
                                children: [new Paragraph({ text: mainDim, bold: true })],
                                rowSpan: subDims.length,
                                shading: { fill: 'F1F5F9' },
                                verticalAlign: VerticalAlign.CENTER
                            }));
                        }

                        cells.push(new TableCell({
                            children: [new Paragraph({ text: subDim, size: 20 })],
                            shading: { fill: 'FAFAFA' }
                        }));

                        parks.forEach(park => {
                            cells.push(new TableCell({
                                children: [new Paragraph({ text: ((currentData.details[key] || {})[park] || '').slice(0, 400), size: 20 })]
                            }));
                        });

                        detailRows.push(new TableRow({ children: cells }));
                    });
                });

                const summaryRows = [];
                summaryRows.push(new TableRow({
                    children: [
                        new TableCell({ children: [new Paragraph({ text: '评价维度', bold: true })], shading: { fill: 'F3F4F6' } }),
                        ...parks.map(park => new TableCell({
                            children: [new Paragraph({ text: park + (park === targetParkName ? '（本园区）' : ''), bold: true, alignment: AlignmentType.CENTER })],
                            shading: { fill: park === targetParkName ? 'DBEAFE' : 'F3F4F6' }
                        }))
                    ]
                }));

                mainDimensions.forEach(dim => {
                    summaryRows.push(new TableRow({
                        children: [
                            new TableCell({ children: [new Paragraph({ text: dim, bold: true })], shading: { fill: 'F9FAFB' } }),
                            ...parks.map(park => new TableCell({
                                children: [new Paragraph({ text: ((currentData.summaries[dim] || {})[park] || '').slice(0, 50) })]
                            }))
                        ]
                    }));
                });

                const scoreRows = [];
                scoreRows.push(new TableRow({
                    children: [
                        new TableCell({ children: [new Paragraph({ text: '评价维度', bold: true })], shading: { fill: 'F3F4F6' } }),
                        ...parks.map(park => new TableCell({
                            children: [new Paragraph({ text: park + (park === targetParkName ? '（本园区）' : ''), bold: true, alignment: AlignmentType.CENTER })],
                            shading: { fill: park === targetParkName ? 'DBEAFE' : 'F3F4F6' }
                        }))
                    ]
                }));

                mainDimensions.forEach(dim => {
                    scoreRows.push(new TableRow({
                        children: [
                            new TableCell({ children: [new Paragraph({ text: dim, bold: true })], shading: { fill: 'F9FAFB' } }),
                            ...parks.map(park => new TableCell({
                                children: [new Paragraph({
                                    text: (((currentData.scores[dim] || {})[park]) || 0).toFixed(1),
                                    bold: true,
                                    alignment: AlignmentType.CENTER
                                })]
                            }))
                        ]
                    }));
                });

                const commonBorder = {
                    top: { style: BorderStyle.SINGLE, size: 1, color: 'D1D5DB' },
                    bottom: { style: BorderStyle.SINGLE, size: 1, color: 'D1D5DB' },
                    left: { style: BorderStyle.SINGLE, size: 1, color: 'D1D5DB' },
                    right: { style: BorderStyle.SINGLE, size: 1, color: 'D1D5DB' },
                    insideHorizontal: { style: BorderStyle.SINGLE, size: 1, color: 'E5E7EB' },
                    insideVertical: { style: BorderStyle.SINGLE, size: 1, color: 'E5E7EB' }
                };

                const detailTable = new Table({ rows: detailRows, width: { size: 100, type: WidthType.PERCENTAGE }, borders: commonBorder });
                const summaryTable = new Table({ rows: summaryRows, width: { size: 100, type: WidthType.PERCENTAGE }, borders: commonBorder });
                const scoreTable = new Table({ rows: scoreRows, width: { size: 100, type: WidthType.PERCENTAGE }, borders: commonBorder });

                const doc = new Document({
                    sections: [{
                        properties: {},
                        children: [
                            new Paragraph({
                                text: '产业园区竞争力对比分析报告',
                                heading: HeadingLevel.TITLE,
                                alignment: AlignmentType.CENTER,
                                spacing: { after: 360 }
                            }),
                            new Paragraph({
                                children: [
                                    new TextRun({ text: '生成时间：', bold: true }),
                                    new TextRun(new Date().toLocaleString('zh-CN')),
                                    new TextRun({ text: '    分析模型：', bold: true }),
                                    new TextRun(currentModel + ' (Tavily数据增强)')
                                ],
                                spacing: { after: 320 }
                            }),
                            new Paragraph({ text: '一、园区竞争力详细情况对比表', heading: HeadingLevel.HEADING_1, spacing: { before: 320, after: 180 } }),
                            detailTable,
                            new Paragraph({ text: '二、园区竞争力核心特征总结表', heading: HeadingLevel.HEADING_1, spacing: { before: 320, after: 180 } }),
                            summaryTable,
                            new Paragraph({ text: '三、园区竞争力数值评分表', heading: HeadingLevel.HEADING_1, spacing: { before: 320, after: 180 } }),
                            scoreTable,
                            new Paragraph({ text: '四、竞争力对比分析总结报告', heading: HeadingLevel.HEADING_1, spacing: { before: 320, after: 180 } }),
                            ...String(currentData.report || '').split(/\n\n+/).map(para => new Paragraph({
                                text: para.trim(),
                                alignment: AlignmentType.JUSTIFIED,
                                indent: { firstLine: 480 },
                                spacing: { after: 180 }
                            }))
                        ]
                    }]
                });

                const blob = await Packer.toBlob(doc);
                saveAs(blob, `园区竞争力对比分析报告_${new Date().toISOString().slice(0, 10)}.docx`);
            } catch (error) {
                console.error('Word导出失败:', error);
                alert('Word导出失败：' + error.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }
    </script>
