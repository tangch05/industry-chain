<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>产业园区竞争力智能对比分析系统</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://unpkg.com/docx@7.1.0/build/index.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Noto Sans SC', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
        }
        .official-text {
            font-family: 'Noto Serif SC', serif;
            line-height: 1.8;
            text-align: justify;
        }
        .glass-panel {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        }
        .loading-spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #3b82f6;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .fade-in {
            animation: fadeIn 0.5s ease-in;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .editable-cell {
            transition: all 0.3s ease;
            position: relative;
        }
        .editable-cell:hover {
            background-color: rgba(59, 130, 246, 0.05);
            box-shadow: inset 0 0 0 2px rgba(59, 130, 246, 0.25);
        }
        .editable-cell:focus {
            outline: none;
            background-color: rgba(59, 130, 246, 0.1);
            box-shadow: inset 0 0 0 2px rgba(59, 130, 246, 0.45);
        }
        .score-input {
            width: 60px;
            text-align: center;
            border: 1px solid transparent;
            background: transparent;
            font-weight: bold;
            color: #1f2937;
            border-radius: 4px;
            padding: 2px;
        }
        .score-input:hover, .score-input:focus {
            border-color: #3b82f6;
            background: white;
            outline: none;
        }
        .main-dim-cell {
            background-color: #f1f5f9;
            font-weight: 600;
            color: #1e3a8a;
            vertical-align: middle;
        }
        .sub-dim-cell {
            background-color: #fafafa;
            color: #4b5563;
            font-size: 0.9em;
        }
        .btn-refresh {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            transition: all 0.3s;
        }
        .btn-refresh:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        }
        .btn-refresh:active {
            transform: translateY(0);
        }
        .search-status {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            background: rgba(16, 185, 129, 0.1);
            color: #059669;
            border-radius: 20px;
            font-size: 0.85rem;
            margin-left: 10px;
        }
        .search-status::before {
            content: '';
            width: 6px;
            height: 6px;
            background: #10b981;
            border-radius: 50%;
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        .chat-history {
            max-height: 180px;
            overflow-y: auto;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            padding: 10px;
            background: #ffffff;
        }
        .chat-user {
            background: #eff6ff;
            color: #1e3a8a;
            border-left: 3px solid #3b82f6;
        }
        .chat-ai {
            background: #f8fafc;
            color: #374151;
            border-left: 3px solid #64748b;
        }
        .chat-msg {
            border-radius: 8px;
            padding: 8px 10px;
            margin-bottom: 8px;
            font-size: 13px;
            line-height: 1.5;
            white-space: pre-wrap;
        }
        .park-bar-1 { background: rgba(239, 68, 68, 0.75); }
        .park-bar-2 { background: rgba(59, 130, 246, 0.75); }
        .park-bar-3 { background: rgba(16, 185, 129, 0.75); }
        .park-bar-4 { background: rgba(245, 158, 11, 0.75); }
        .park-bar-5 { background: rgba(99, 102, 241, 0.75); }
        .park-bar-6 { background: rgba(236, 72, 153, 0.75); }
        @media print {
            .no-print { display: none !important; }
            .glass-panel { box-shadow: none; border: 1px solid #ddd; }
        }
    </style>
</head>
<body class="p-4 md:p-8">

    <div class="max-w-7xl mx-auto mb-8 no-print">
        <div class="glass-panel rounded-2xl p-6 md:p-8">
            <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mb-2 text-center">产业园区竞争力智能对比分析系统</h1>
            <p class="text-gray-600 text-center mb-8">基于AI大模型+实时数据搜索的多维度竞争力评估</p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">对比园区名称（用顿号、逗号或空格分隔）</label>
                    <input type="text" id="compareParks" placeholder="例如：苏州工业园区、深圳南山科技园、上海张江高科"
                           class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">本园区名称</label>
                    <input type="text" id="targetPark" placeholder="例如：杭州未来科技城"
                           class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">硅基流动 API 密钥 <span class="text-red-500">*</span></label>
                    <input type="password" id="apiKey" placeholder="请输入硅基流动API密钥 (sk-...)"
                           class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Tavily API 密钥 <span class="text-red-500">*</span></label>
                    <input type="password" id="tavilyApiKey" placeholder="请输入Tavily API密钥 (tvly-...)"
                           class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">选择AI模型</label>
                    <select id="modelSelect" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition bg-white">
                        <option value="deepseek-ai/DeepSeek-V3">DeepSeek-V3 (深度求索)</option>
                        <option value="Pro/deepseek-ai/DeepSeek-R1">DeepSeek-R1 (推理版)</option>
                        <option value="Doubao/Doubao-pro-32k">豆包 Pro (字节跳动)</option>
                        <option value="Doubao/Doubao-lite-32k">豆包 Lite (轻量版)</option>
                    </select>
                </div>
            </div>

            <div class="flex flex-wrap gap-3 justify-center items-center">
                <button onclick="startAnalysis()" id="analyzeBtn" class="px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg shadow-lg transform hover:scale-105 transition flex items-center gap-2">
                    <span>开始智能分析</span>
                </button>
                <button onclick="confirmGenerate()" id="confirmGenerateBtn" disabled class="px-8 py-3 bg-emerald-600 text-white font-semibold rounded-lg shadow-lg transition disabled:opacity-40 disabled:cursor-not-allowed">
                    确认生成
                </button>
                <button onclick="refreshAnalysis()" id="refreshBtn" class="hidden px-6 py-3 btn-refresh font-semibold rounded-lg shadow-lg flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    <span>刷新数据</span>
                </button>
                <button onclick="exportPDF()" id="exportBtn" class="px-6 py-3 bg-gray-700 hover:bg-gray-800 text-white font-semibold rounded-lg shadow-lg transition flex items-center gap-2 hidden">
                    <span>导出PDF</span>
                </button>
                <button onclick="exportWord()" id="exportWordBtn" class="px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg shadow-lg transition flex items-center gap-2 hidden">
                    <span>导出Word</span>
                </button>
                <button onclick="resetForm()" class="px-6 py-3 bg-white hover:bg-gray-50 text-gray-700 font-semibold rounded-lg border border-gray-300 transition">
                    重置
                </button>
                <div id="searchStatus" class="search-status hidden">Tavily实时搜索已启用</div>
            </div>

            <div id="loadingArea" class="hidden mt-6 text-center">
                <div class="loading-spinner mx-auto mb-2"></div>
                <p class="text-gray-600" id="loadingText">正在搜索园区最新数据...</p>
                <p class="text-sm text-gray-500 mt-1" id="loadingSubText">Tavily搜索+AI分析联合驱动</p>
            </div>

            <div id="refreshLoadingArea" class="hidden mt-4 text-center text-sm text-purple-600 bg-purple-50 rounded-lg p-3">
                <span class="inline-block animate-pulse">正在根据编辑内容重新计算评分和生成报告...</span>
            </div>
        </div>
    </div>

    <div id="stepOneArea" class="max-w-7xl mx-auto hidden space-y-6 mb-8">
        <div class="glass-panel rounded-2xl p-6">
            <h2 class="text-xl font-bold text-gray-800 mb-2">第一步：四维详细情况优化</h2>
            <p class="text-sm text-gray-600">每个维度均支持单元格手动编辑与独立多轮AI优化。完成后点击上方“确认生成”。</p>
        </div>
        <div id="stepOneCards" class="grid grid-cols-1 xl:grid-cols-2 gap-6"></div>
    </div>

    <div id="resultArea" class="max-w-7xl mx-auto space-y-8 hidden">
        <div class="glass-panel rounded-2xl p-6 overflow-hidden">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-xl font-bold text-gray-800 flex items-center gap-2">
                    <span class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-sm font-bold">1</span>
                    园区竞争力详细情况对比表
                    <span class="text-xs font-normal text-gray-500 ml-2">（可编辑，限400字内）</span>
                </h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm border-collapse border border-gray-300" id="detailTable">
                    <thead>
                        <tr class="bg-gray-100">
                            <th class="border border-gray-300 px-4 py-3 text-left font-bold text-gray-800 w-32">评估维度</th>
                            <th class="border border-gray-300 px-4 py-3 text-left font-bold text-gray-800 w-36">细化评估维度</th>
                        </tr>
                    </thead>
                    <tbody id="detailTableBody"></tbody>
                </table>
            </div>
        </div>

        <div class="glass-panel rounded-2xl p-6 overflow-hidden">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-xl font-bold text-gray-800 flex items-center gap-2">
                    <span class="w-8 h-8 bg-purple-100 text-purple-600 rounded-full flex items-center justify-center text-sm font-bold">2</span>
                    园区竞争力核心特征总结表
                    <span class="text-xs font-normal text-gray-500 ml-2">（可编辑，含相对能力可视化）</span>
                </h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm border-collapse border border-gray-300" id="summaryTable">
                    <thead>
                        <tr class="bg-gray-100">
                            <th class="border border-gray-300 px-4 py-3 text-left font-bold text-gray-800 w-40">评价维度</th>
                        </tr>
                    </thead>
                    <tbody id="summaryTableBody"></tbody>
                </table>
            </div>
        </div>

        <div class="glass-panel rounded-2xl p-6 overflow-hidden">
            <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
                <span class="w-8 h-8 bg-green-100 text-green-600 rounded-full flex items-center justify-center text-sm font-bold">3</span>
                园区竞争力数值评分表
                <span class="text-xs font-normal text-gray-500 ml-2">（10分制，可直接点击数字编辑，自动联动可视化）</span>
            </h2>
            <div class="overflow-x-auto">
                <table class="w-full text-sm border-collapse border border-gray-300" id="scoreTable">
                    <thead>
                        <tr class="bg-gray-100">
                            <th class="border border-gray-300 px-4 py-3 text-left font-bold text-gray-800 w-40">评价维度</th>
                        </tr>
                    </thead>
                    <tbody id="scoreTableBody"></tbody>
                </table>
            </div>
        </div>

        <div class="glass-panel rounded-2xl p-8">
            <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
                <span class="w-8 h-8 bg-orange-100 text-orange-600 rounded-full flex items-center justify-center text-sm font-bold">4</span>
                竞争力对比分析总结报告
            </h2>
            <div id="summaryText" class="official-text text-gray-800 text-base leading-relaxed space-y-4"></div>
        </div>

        <div class="text-center text-gray-500 text-sm pb-8">
            <p>生成时间：<span id="generateTime"></span> | 分析模型：<span id="usedModel"></span></p>
            <p class="mt-1 text-xs text-gray-400">本报告由AI基于Tavily实时搜索数据自动生成，仅供参考</p>
        </div>
    </div>

    <script>
        const BASE_URL = 'https://api.siliconflow.cn/v1';

        let currentParks = [];
        let targetParkName = '';
        let currentModel = '';
        let userApiKey = '';
        let userTavilyApiKey = '';

        let detailedData = {};
        let conversationHistory = {};
        let currentData = null;

        const parkBarColors = ['park-bar-1', 'park-bar-2', 'park-bar-3', 'park-bar-4', 'park-bar-5', 'park-bar-6'];

        const stepOneDimensionStructure = {
            '产业集聚力': ['产业整体规模', '龙头企业带动', '产业链完整性', '产业链位置'],
            '创新突破力': ['现有技术能力', '创新企业比例', '创新生态环境', '未来产业实力'],
            '要素吸引力': ['本地资源优势', '产业政策力度', '综合营商环境', '品牌影响力'],
            '风险抵御力': ['产业周期位置', '土地开放空间', '债务负担水平', '环境承载能力']
        };

        const finalDimensionStructure = {
            ...stepOneDimensionStructure,
            '综合竞争力评价': ['综合评价']
        };

        const mainDimensions = ['产业集聚力', '创新突破力', '要素吸引力', '风险抵御力', '综合竞争力评价'];

        async function searchParkData(parkName) {
            if (!userTavilyApiKey) {
                throw new Error('请先填写 Tavily API 密钥');
            }

            try {
                const response = await fetch('https://api.tavily.com/search', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        api_key: userTavilyApiKey,
                        query: `${parkName} 2024 产业园区 经济数据 产业规模 企业数量 发展规划`,
                        search_depth: 'advanced',
                        include_answer: true,
                        max_results: 5
                    })
                });

                if (!response.ok) {
                    throw new Error('搜索失败');
                }
                const data = await response.json();
                return { park: parkName, answer: data.answer || '', results: data.results || [] };
            } catch (error) {
                console.error(`搜索${parkName}失败:`, error);
                return { park: parkName, answer: '', results: [] };
            }
        }

        async function callAI(prompt, model, apiKey) {
            const response = await fetch(`${BASE_URL}/chat/completions`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${apiKey}`
                },
                body: JSON.stringify({
                    model,
                    messages: [
                        {
                            role: 'system',
                            content: '你是一位资深的产业园区竞争力分析专家，擅长基于实时数据进行多维度产业分析和量化评估。请确保输出结构严格、内容客观。'
                        },
                        {
                            role: 'user',
                            content: prompt
                        }
                    ],
                    temperature: 0.4,
                    max_tokens: 7000
                })
            });

            if (!response.ok) {
                if (response.status === 401) {
                    throw new Error('API密钥无效或已过期，请检查密钥');
                }
                throw new Error(`API调用失败: ${response.status}`);
            }

            const data = await response.json();
            return data.choices[0].message.content;
        }

        async function startAnalysis() {
            const compareInput = document.getElementById('compareParks').value.trim();
            const targetInput = document.getElementById('targetPark').value.trim();
            const model = document.getElementById('modelSelect').value;
            const apiKeyInput = document.getElementById('apiKey').value.trim();
            const tavilyKeyInput = document.getElementById('tavilyApiKey').value.trim();

            if (!compareInput || !targetInput) {
                alert('请填写完整的园区名称信息');
                return;
            }
            if (!apiKeyInput) {
                alert('请输入硅基流动API密钥');
                document.getElementById('apiKey').focus();
                return;
            }
            if (!tavilyKeyInput) {
                alert('请输入 Tavily API 密钥');
                document.getElementById('tavilyApiKey').focus();
                return;
            }

            const compareParks = compareInput.split(/[、,，\s]+/).filter(Boolean);
            const allParks = [...compareParks, targetInput];
            if (allParks.length < 2) {
                alert('请至少输入一个对比园区和本园区');
                return;
            }

            currentParks = allParks;
            targetParkName = targetInput;
            currentModel = model;
            userApiKey = apiKeyInput;
            userTavilyApiKey = tavilyKeyInput;

            document.getElementById('loadingArea').classList.remove('hidden');
            document.getElementById('analyzeBtn').disabled = true;
            document.getElementById('confirmGenerateBtn').disabled = true;
            document.getElementById('searchStatus').classList.remove('hidden');
            document.getElementById('stepOneArea').classList.add('hidden');
            document.getElementById('resultArea').classList.add('hidden');

            try {
                document.getElementById('loadingText').textContent = '正在通过Tavily搜索园区最新数据...';
                const searchResults = await Promise.all(allParks.map(searchParkData));

                document.getElementById('loadingText').textContent = '正在生成四维详细情况小表...';
                const prompt = buildStepOnePrompt(allParks, targetInput, searchResults);
                const response = await callAI(prompt, model, userApiKey);
                const parsed = parseStepOneResponse(response, allParks);

                detailedData = parsed.details;
                initConversationHistory();
                renderStepOneArea();

                document.getElementById('confirmGenerateBtn').disabled = false;
                document.getElementById('stepOneArea').classList.remove('hidden');
                document.getElementById('stepOneArea').classList.add('fade-in');
                setTimeout(() => {
                    document.getElementById('stepOneArea').scrollIntoView({ behavior: 'smooth' });
                }, 120);
            } catch (error) {
                console.error('第一步分析失败:', error);
                alert('分析过程中出现错误：' + error.message);
            } finally {
                document.getElementById('loadingArea').classList.add('hidden');
                document.getElementById('analyzeBtn').disabled = false;
            }
        }

        function buildStepOnePrompt(parks, targetPark, searchResults) {
            let searchContext = '【Tavily实时搜索数据】\n';
            searchResults.forEach(result => {
                searchContext += `\n=== ${result.park} 最新信息 ===\n`;
                searchContext += `摘要：${result.answer || '暂无摘要'}\n`;
                (result.results || []).slice(0, 3).forEach((r, idx) => {
                    searchContext += `${idx + 1}. ${r.title}: ${(r.content || '').substring(0, 220)}...\n`;
                });
            });

            const requiredKeys = [];
            Object.entries(stepOneDimensionStructure).forEach(([mainDim, subDims]) => {
                subDims.forEach(sub => requiredKeys.push(`${mainDim}-${sub}`));
            });

            return `${searchContext}

请仅针对以下园区生成前四个主维度的详细描述：${parks.join('、')}。
其中${targetPark}为本园区，其他为对比园区。

要求：
1. 只输出前四个主维度（产业集聚力、创新突破力、要素吸引力、风险抵御力）。
2. 每个子维度、每个园区一段描述，单段不超过400字。
3. 引用搜索数据中的2024-2025公开信息，缺失时可给出谨慎判断。
4. 不要输出综合竞争力评价。

严格返回JSON，不要包含任何其他文字，结构如下：
{
  "details": {
    "产业集聚力-产业整体规模": {"园区A": "...", "园区B": "..."},
    "产业集聚力-龙头企业带动": {"园区A": "...", "园区B": "..."},
