                currentParks.forEach(park => {
                    const val = parseFloat((scores[dim] || {})[park]);
                    const fixed = Number.isFinite(val) ? Math.min(10, Math.max(0, val)) : 7.0;
                    output[dim][park] = parseFloat(fixed.toFixed(1));
                });
            });
            return output;
